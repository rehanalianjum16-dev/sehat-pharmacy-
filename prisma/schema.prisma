// datasource and generator setup
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ==========================================
// 1. SECURITY & USER MANAGEMENT
// ==========================================

enum Role {
  ADMIN
  MANAGER
  CASHIER
}

enum AccountStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

model User {
  id               String        @id @default(uuid())
  email            String        @unique
  name             String
  passwordHash     String
  role             Role          @default(CASHIER)
  status           AccountStatus @default(PENDING_APPROVAL)
  
  // Security parameters
  twoFactorEnabled Boolean       @default(false)
  twoFactorSecret  String?
  loginAttempts    Int           @default(0)
  lockoutUntil     DateTime?
  
  // Branch relationship (Multi-branch ready)
  branchId         String?
  branch           Branch?       @relation(fields: [branchId], references: [id], onDelete: SetNull)
  
  // Audits & Sessions
  sessions         Session[]
  auditLogs        AuditLog[]
  adjustmentsMade  StockAdjustment[]
  transfersLogged  StockTransfer[]
  salesRecorded    Sale[]

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([email])
  @@index([branchId])
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionToken String   @unique
  
  // Active session parameters
  ipAddress    String?
  userAgent    String?
  location     String?
  lastActive   DateTime @default(now())
  isValid      Boolean  @default(true)
  
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([sessionToken])
}

model AuditLog {
  id          String   @id @default(uuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  username    String   // Snapshotted username for quick queries
  action      String   // E.g., "Updated Product Panadol Stock", "Authorized Sale Return"
  ipAddress   String?
  timestamp   DateTime @default(now())

  @@index([userId])
  @@index([timestamp])
}

// ==========================================
// 2. MULTI-BRANCH READY LOCATIONS
// ==========================================

model Branch {
  id              String            @id @default(uuid())
  name            String            @unique
  address         String
  phone           String
  
  users           User[]
  batches         Batch[]
  sales           Sale[]
  purchaseOrders  PurchaseOrder[]
  adjustments     StockAdjustment[]
  transfersFrom   StockTransfer[]   @relation("SourceBranch")
  transfersTo     StockTransfer[]   @relation("TargetBranch")

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

// ==========================================
// 3. INVENTORY & BATCH MANAGEMENT
// ==========================================

model Category {
  id          String     @id @default(uuid())
  name        String     @unique
  description String?
  medicines   Medicine[]
  createdAt   DateTime   @default(now())
}

model Medicine {
  id             String              @id @default(uuid())
  name           String
  genericName    String              // Formula
  sku            String              @unique // Barcode
  minStockAlert  Int                 @default(10)
  
  categoryId     String
  category       Category            @relation(fields: [categoryId], references: [id])
  
  batches        Batch[]
  saleItems      SaleItem[]
  poItems        PurchaseOrderItem[]
  adjustments    StockAdjustment[]
  transfers      StockTransfer[]

  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([sku])
  @@index([name])
  @@index([genericName])
}

// Batch configuration for FIFO Stock Execution
model Batch {
  id             String            @id @default(uuid())
  medicineId     String
  medicine       Medicine          @relation(fields: [medicineId], references: [id], onDelete: Cascade)
  branchId       String
  branch         Branch            @relation(fields: [branchId], references: [id], onDelete: Cascade)
  
  batchNumber    String
  stock          Int               @default(0)
  purchasePrice  Decimal           @db.Decimal(12, 2)
  retailPrice    Decimal           @db.Decimal(12, 2)
  expiryDate     DateTime
  
  saleItems      SaleItem[]
  adjustments    StockAdjustment[]
  transfers      StockTransfer[]

  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([medicineId, branchId])
  @@index([expiryDate]) // Quick index for batch expiry notification alerts
}

// Stock Adjustment Logs (Damage, Expired, Loss)
model StockAdjustment {
  id          String   @id @default(uuid())
  branchId    String
  branch      Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  medicineId  String
  medicine    Medicine @relation(fields: [medicineId], references: [id], onDelete: Cascade)
  batchId     String
  batch       Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  
  quantity    Int      // Negative for write-offs, positive for replenishments
  type        String   // E.g., "DAMAGED", "LOST", "EXPIRED", "RETURN_SCRAP"
  reason      String
  
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  timestamp   DateTime @default(now())

  @@index([branchId])
  @@index([medicineId])
}

// Stock Transfer Ledger between Branches
model StockTransfer {
  id             String   @id @default(uuid())
  sourceBranchId String
  sourceBranch   Branch   @relation("SourceBranch", fields: [sourceBranchId], references: [id], onDelete: Cascade)
  targetBranchId String
  targetBranch   Branch   @relation("TargetBranch", fields: [targetBranchId], references: [id], onDelete: Cascade)
  
  medicineId     String
  medicine       Medicine @relation(fields: [medicineId], references: [id], onDelete: Cascade)
  batchId        String
  batch          Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  
  quantity       Int
  status         String   // E.g., "PENDING", "COMPLETED", "CANCELLED"
  
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  timestamp      DateTime @default(now())

  @@index([sourceBranchId, targetBranchId])
}

// ==========================================
// 4. PROCUREMENT (PURCHASES & SUPPLIERS)
// ==========================================

model Supplier {
  id             String          @id @default(uuid())
  companyName    String          @unique
  contactPerson  String
  phone          String
  email          String?
  ledgerBalance  Decimal         @default(0.00) @db.Decimal(12, 2)
  
  purchaseOrders PurchaseOrder[]
  payments       SupplierPayment[]

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model PurchaseOrder {
  id            String              @id @default(uuid())
  branchId      String
  branch        Branch              @relation(fields: [branchId], references: [id], onDelete: Cascade)
  invoiceNumber String              // Supplier invoice ID
  supplierId    String
  supplier      Supplier            @relation(fields: [supplierId], references: [id])
  
  date          DateTime            @default(now())
  totalAmount   Decimal             @db.Decimal(12, 2)
  paidAmount    Decimal             @db.Decimal(12, 2)
  balanceDue    Decimal             @db.Decimal(12, 2)
  status        String              // E.g., "RECEIVED", "PENDING", "PARTIAL"
  
  items         PurchaseOrderItem[]

  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([supplierId])
  @@index([branchId])
}

model PurchaseOrderItem {
  id              String        @id @default(uuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  
  medicineId      String
  medicine        Medicine      @relation(fields: [medicineId], references: [id])
  batchNumber     String
  quantity        Int
  purchasePrice   Decimal       @db.Decimal(12, 2)
  retailPrice     Decimal       @db.Decimal(12, 2)
  expiryDate      DateTime

  @@index([purchaseOrderId])
}

model SupplierPayment {
  id              String   @id @default(uuid())
  supplierId      String
  supplier        Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  
  amountPaid      Decimal  @db.Decimal(12, 2)
  paymentMethod   String   // E.g., "Bank Wire", "Cash"
  referenceNumber String?
  date            DateTime @default(now())

  @@index([supplierId])
}

// ==========================================
// 5. SALES & POINT OF SALE (POS)
// ==========================================

model Customer {
  id            String                       @id @default(uuid())
  name          String
  phone         String?                      @unique
  address       String?
  loyaltyPoints Int                          @default(0)
  
  sales         Sale[]
  loyaltyLogs   CustomerLoyaltyTransaction[]

  createdAt     DateTime                     @default(now())
  updatedAt     DateTime                     @updatedAt

  @@index([phone])
}

model Sale {
  id             String                       @id @default(uuid())
  branchId       String
  branch         Branch                       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  invoiceNumber  String                       @unique
  date           DateTime                     @default(now())
  
  // Billed totals
  subtotal       Decimal                      @db.Decimal(12, 2)
  taxAmount      Decimal                      @db.Decimal(12, 2)
  discountAmount Decimal                      @db.Decimal(12, 2)
  grandTotal     Decimal                      @db.Decimal(12, 2)
  
  cashierId      String
  cashier        User                         @relation(fields: [cashierId], references: [id])
  customerId     String?
  customer       Customer?                    @relation(fields: [customerId], references: [id])
  
  paymentMethod  String                       // E.g., "Cash", "Card", "Split"
  
  // Return configuration
  isReturned     Boolean                      @default(false)
  returnReason   String?
  originalSaleId String?                      // If exchanged, traces back to original ID
  
  items          SaleItem[]
  splitPayments  SalePaymentSplit[]
  loyaltyLogs    CustomerLoyaltyTransaction[]

  createdAt      DateTime                     @default(now())

  @@index([invoiceNumber])
  @@index([branchId])
  @@index([date])
}

model SaleItem {
  id         String   @id @default(uuid())
  saleId     String
  sale       Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  medicineId String
  medicine   Medicine @relation(fields: [medicineId], references: [id])
  batchId    String
  batch      Batch    @relation(fields: [batchId], references: [id])
  
  quantity   Int
  retailPrice Decimal  @db.Decimal(12, 2)
  total      Decimal  @db.Decimal(12, 2)

  @@index([saleId])
  @@index([medicineId])
}

model SalePaymentSplit {
  id        String   @id @default(uuid())
  saleId    String
  sale      Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  
  method    String   // E.g., "Cash", "EasyPaisa", "Card"
  amount    Decimal  @db.Decimal(12, 2)

  @@index([saleId])
}

model CustomerLoyaltyTransaction {
  id             String   @id @default(uuid())
  customerId     String
  customer       Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  saleId         String?
  sale           Sale?    @relation(fields: [saleId], references: [id], onDelete: SetNull)
  
  pointsEarned   Int      @default(0)
  pointsRedeemed Int      @default(0)
  date           DateTime @default(now())

  @@index([customerId])
}
